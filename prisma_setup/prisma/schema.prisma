generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



model User {
  id    String     @id 
  email String  @unique 
  name  String?
  role String?
  country String?
  experience String?
  avatar String?
}